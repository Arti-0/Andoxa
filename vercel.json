{
  "buildCommand": "bun run build",
  "outputDirectory": ".next",
  "installCommand": "bun install",
  "framework": "nextjs",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/**/*.ts": {
      "maxDuration": 300
    },
    "src/app/api/workflows/**/*.ts": {
      "maxDuration": 300
    },
    "src/app/api/cron/**/*.ts": {
      "maxDuration": 60
    },
    "src/app/api/cron/campaign-jobs/route.ts": {
      "maxDuration": 120
    },
    "src/app/api/cron/workflow-steps/route.ts": {
      "maxDuration": 120
    }
  },
  "crons": [
    {
      "path": "/api/booking/reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/enrichment-jobs",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/campaign-jobs",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/workflow-steps",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/apply-scheduled-downgrades",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/linkedin-acceptance-reconciler",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/unipile-accounts-reconcile",
      "schedule": "17 * * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/webhooks/stripe",
      "destination": "/api/paiements/webhook"
    }
  ],
  "redirects": [
    {
      "source": "/www/(.*)",
      "destination": "/$1",
      "permanent": true
    },
    {
      "source": "/terms",
      "destination": "/mentions-legales",
      "permanent": true
    },
    {
      "source": "/terms-of-use",
      "destination": "/cgu",
      "permanent": true
    }
  ],
  "env": {
    "NEXT_PUBLIC_DEBUG_MODE": "false",
    "NEXT_PUBLIC_LOG_LEVEL": "error"
  }
}
